{
  "name": "openclaw-dashboard",
  "version": "1.0.0",
  "description": "Real-time monitoring dashboard for OpenClaw AI agents",
  "main": "dist/apps/api/src/main.js",
  "type": "commonjs",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "prestart": "npx prisma generate --schema=packages/db/prisma/schema.prisma",
    "start": "node dist/apps/api/src/main.js",
    "build": "npx prisma generate --schema=packages/db/prisma/schema.prisma && tsc -p tsconfig.json && npx vite build --config apps/web/vite.config.ts",
    "build:ci": "npx prisma generate --schema=packages/db/prisma/schema.prisma && tsc -p tsconfig.json --noEmitOnError false --skipLibCheck && npx vite build --config apps/web/vite.config.ts",
    "build:web": "npx vite build --config apps/web/vite.config.ts",
    "build:gateway": "tsc -p apps/gateway/tsconfig.json",
    "dev": "NODE_ENV=development ts-node -P tsconfig.json apps/api/src/main.ts",
    "dev:web": "npx vite --config apps/web/vite.config.ts",
    "dev:gateway": "NODE_ENV=development ts-node -r tsconfig-paths/register -P apps/gateway/tsconfig.json apps/gateway/src/main.ts",
    "start:gateway": "node apps/gateway/dist/main.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:profile-engine": "jest --selectProjects=profile-engine",
    "test:workspace-engine": "jest --selectProjects=workspace-engine",
    "test:api": "jest --selectProjects=api",
    "test:run-engine": "jest --selectProjects=run-engine",
    "test:e2e:run-engine": "jest --config packages/run-engine/src/__tests__/e2e/jest.e2e.config.ts --runInBand"
  },
  "prisma": {
    "schema": "packages/db/prisma/schema.prisma"
  },
  "keywords": [
    "openclaw",
    "dashboard",
    "agents",
    "monitoring"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.26.0",
    "@hono/node-server": "^1.19.14",
    "@mistralai/mistralai": "^1.3.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@nestjs/common": "^10.4.22",
    "@nestjs/core": "^10.4.22",
    "@nestjs/event-emitter": "^2.1.1",
    "@nestjs/platform-express": "^10.4.22",
    "@nestjs/platform-socket.io": "^10.4.22",
    "@nestjs/websockets": "^10.4.22",
    "@prisma/client": "^5.14.0",
    "@whiskeysockets/baileys": "^6.7.21",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "async-mutex": "^0.5.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.4.1",
    "helmet": "^7.1.0",
    "hono": "^4.12.16",
    "jose": "^6.2.3",
    "js-yaml": "^4.1.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.344.0",
    "node-cron": "^3.0.3",
    "openai": "^4.52.0",
    "pino": "^9.14.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.53.0",
    "react-router-dom": "^6.26.0",
    "reactflow": "^11.11.0",
    "recharts": "^3.8.1",
    "rxjs": "^7.8.0",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "ws": "^8.15.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.0",
    "@types/js-yaml": "^4.0.9",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/supertest": "^6.0.3",
    "@types/ws": "^8.5.10",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "jest": "^29.5.0",
    "postcss": "^8.4.0",
    "prisma": "^5.22.0",
    "supertest": "^6.3.4",
    "tailwindcss": "^3.4.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.0.0",
    "vite": "^5.4.0"
  }
}
