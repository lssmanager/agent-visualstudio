# WebChat
WEBCHAT_PORT=3002
WEBCHAT_EMBED_SECRET=change-me-in-production

# Telegram (optional)
# TELEGRAM_BOT_TOKEN=

# OpenAI (optional)
# OPENAI_API_KEY=

# Anthropic (optional)
