// ─────────────────────────────────────────────────────────────────────────────
// Prisma schema — agent-visualstudio
// Modelos base:  Workspace, Agent, Flow, Skill, Policy, Hook
//                Channel, LlmProvider, ProviderCatalog, OAuthToken
// Modelos plan:  Run, RunStep, ConversationMessage
//                BudgetPolicy, BudgetIncident, CostEvent
//                ModelPolicy, AgentProfile
//                Approval, ActivityLog
// Catálogo LLM:  ProviderCredential, ModelCatalogEntry
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Workspace ────────────────────────────────────────────────────────────────
model Workspace {
  id          String   @id @default(cuid())
  name        String
  description String?
  config      Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  agents              Agent[]
  flows               Flow[]
  skills              Skill[]
  policies            Policy[]
  hooks               Hook[]
  channels            Channel[]
  llmProviders        LlmProvider[]
  runs                Run[]
  budgetPolicies      BudgetPolicy[]
  modelPolicies       ModelPolicy[]
  approvals           Approval[]
  activityLogs        ActivityLog[]
  providerCredentials ProviderCredential[]
}

// ── Agent ─────────────────────────────────────────────────────────────────────
model Agent {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  name        String
  description String?
  role        String?
  goal        String?
  backstory   String?
  model       String    @default("gpt-4o-mini")
  tools       Json      @default("[]")
  config      Json      @default("{}")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  boundChannels  Channel[]    @relation("ChannelAgent")
  profile        AgentProfile?
  runs           Run[]
  modelPolicies  ModelPolicy[]
  approvals      Approval[]
  agentSkills    AgentSkill[]

  @@index([workspaceId])
}

// ── Flow ──────────────────────────────────────────────────────────────────────
model Flow {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  name        String
  description String?
  nodes       Json      @default("[]")
  edges       Json      @default("[]")
  config      Json      @default("{}")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  runs        Run[]

  @@index([workspaceId])
}

// ── Skill ─────────────────────────────────────────────────────────────────────
model Skill {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  name        String
  description String?
  type        String    @default("function")
  config      Json      @default("{}")
  isActive    Boolean   @default(true)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  agentSkills AgentSkill[]

  @@index([workspaceId])
}

// ── AgentSkill ────────────────────────────────────────────────────────────────
model AgentSkill {
  id             String   @id @default(cuid())
  agentId        String
  agent          Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  skillId        String
  skill          Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)
  configOverride Json     @default("{}")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([agentId, skillId])
  @@index([agentId])
  @@index([skillId])
}

// ── Policy ────────────────────────────────────────────────────────────────────
model Policy {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  name        String
  description String?
  rules       Json      @default("[]")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([workspaceId])
}

// ── Hook ──────────────────────────────────────────────────────────────────────
model Hook {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  name        String
  event       String
  action      Json      @default("{}")
  enabled     Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([workspaceId])
}

// ── Channel ───────────────────────────────────────────────────────────────────
// AUDIT-30: añadidos slack y teams al enum ChannelKind para que Run.channelKind
// sea tipado con el enum real en lugar de String? libre.
enum ChannelKind {
  telegram
  whatsapp
  discord
  webchat
  slack
  teams
}

enum ChannelStatus {
  provisioned
  bound
  error
  offline
}

model Channel {
  id          String        @id @default(cuid())
  workspaceId String
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  kind        ChannelKind
  status      ChannelStatus @default(provisioned)
  tokenEnc    String        // AES-256-GCM cifrado: iv:authTag:ciphertext
  meta        Json          @default("{}")  // appId, webhookUrl, etc.

  boundAgentId String?
  boundAgent   Agent?        @relation("ChannelAgent", fields: [boundAgentId], references: [id])

  messages    ConversationMessage[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([workspaceId])
  @@index([boundAgentId])
}

// ── ProviderCatalog ───────────────────────────────────────────────────────────
// Catálogo estático de providers conocidos (semilla via seed.ts).
// Describe capabilities, modelos por defecto y tipo de auth requerida.
// LlmProvider apunta a este catálogo para validar el string provider.

enum ProviderAuthType {
  api_key          // API key estándar (Authorization: Bearer / X-API-Key)
  oauth            // OAuth 2.0 / OIDC (GitHub Copilot, openai-codex)
  aws_credentials  // AWS SigV4 (Amazon Bedrock)
  azure_api_key    // Azure OpenAI (api-key header + deployment URLs)
  none             // Sin auth (Ollama local, LM Studio local, vLLM local)
}

model ProviderCatalog {
  // slug único: "openai" | "anthropic" | "qwen" | "deepseek" | "openrouter" | ...
  id          String           @id  // slug usado en provider field de LlmProvider

  displayName String           // nombre legible: "OpenAI", "Anthropic", etc.
  description String?

  // ── Auth ──
  authType    ProviderAuthType @default(api_key)

  // ── Capabilities ──────────────────────────────────────────────────────────
  // JSON con flags booleanos del set de capacidades del provider.
  // Shape: { chat, streaming, functionCalling, vision, imageGeneration,
  //          videoGeneration, audioTts, audioStt, realtimeVoice, embeddings,
  //          batchApi, codeExecution, webSearch }
  capabilities Json            @default("{}")

  // ── Default models ────────────────────────────────────────────────────────
  // JSON con los modelos recomendados por rol.
  // Shape: { primary, fast, smart, embedding, image, video, tts, stt }
  defaultModels Json           @default("{}")

  // ── Base URL por defecto ──────────────────────────────────────────────────
  // El LlmProvider puede sobreescribirla (útil para Azure, proxies, local).
  defaultBaseUrl String?

  // ── Flags de clasificación ────────────────────────────────────────────────
  isLocalOnly    Boolean       @default(false)  // Ollama, LM Studio, vLLM, SGLang
  isOpenAiCompat Boolean       @default(false)  // acepta OpenAI SDK sin adaptador
  isEnabled      Boolean       @default(true)   // para ocultar providers beta/deprecated

  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  llmProviders LlmProvider[]
}

// ── LlmProvider ───────────────────────────────────────────────────────────────
// Credencial de un workspace hacia un provider del catálogo.
// provider es el slug FK a ProviderCatalog.id (e.g. "openai", "anthropic").
// baseUrl permite override de la URL del catálogo (Azure, proxy, local).

model LlmProvider {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  // FK al catálogo — el slug garantiza que solo providers conocidos sean usados
  provider    String
  catalog     ProviderCatalog @relation(fields: [provider], references: [id])

  // Override de baseUrl del catálogo.
  // null → usar catalog.defaultBaseUrl
  // valor → URL personalizada (Azure endpoint, proxy, Ollama local, etc.)
  baseUrl     String?

  // API key / token cifrado (AES-256-GCM: iv:authTag:ciphertext)
  // null cuando authType = none (Ollama local sin auth) o authType = oauth
  apiKeyEnc   String?

  isDefault   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // OAuth token — solo presente cuando catalog.authType = oauth
  oauthToken  OAuthToken?

  @@unique([workspaceId, provider])
  @@index([workspaceId])
  @@index([provider])
}

// ── OAuthToken ────────────────────────────────────────────────────────────────
model OAuthToken {
  id              String      @id @default(cuid())

  llmProviderId   String      @unique
  llmProvider     LlmProvider @relation(fields: [llmProviderId], references: [id], onDelete: Cascade)

  accessTokenEnc  String      @db.Text
  refreshTokenEnc String?     @db.Text

  expiresAt       DateTime
  accountId       String?
  scopes          String?
  meta            Json        @default("{}")

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([expiresAt])
}

// ── ProviderCredential ────────────────────────────────────────────────────────
// Credencial de una agencia (workspace) hacia un proveedor LLM externo.
// Usada por ProviderCatalogService para sync de catálogo de modelos y
// resolución de modelo → proveedor para callLLM().
//
// Diferencia con LlmProvider:
//   LlmProvider   → apunta a ProviderCatalog (slug estático, semilla)
//   ProviderCredential → credencial dinámica con sync de modelos en DB
//
// type enum:
//   'openai'        → https://api.openai.com/v1/models
//   'anthropic'     → https://api.anthropic.com/v1/models
//   'openrouter'    → https://openrouter.ai/api/v1/models  (50+ sub-providers)
//   'openai_compat' → {baseUrl}/v1/models

model ProviderCredential {
  id          String   @id @default(cuid())

  // agencyId = workspaceId (el servicio usa el término "agency" internamente)
  agencyId    String
  agency      Workspace @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  name             String    // nombre legible: "OpenAI Production", "OpenRouter"
  type             String    // openai | anthropic | openrouter | openai_compat
  baseUrl          String?   // requerido para openai_compat; null = usar default
  apiKeyEncrypted  String    // AES-256-GCM: iv:authTag:ciphertext
  extraHeaders     Json?     // headers extra para el proveedor (e.g. HTTP-Referer)
  isActive         Boolean   @default(true)
  syncedAt         DateTime? // última vez que se ejecutó syncProvider()

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  models      ModelCatalogEntry[]

  @@index([agencyId])
  @@index([agencyId, isActive])
}

// ── ModelCatalogEntry ─────────────────────────────────────────────────────────
// Una entrada del catálogo de modelos disponibles para una agencia.
// Se sincroniza desde las APIs de los proveedores vía ProviderCatalogService.
//
// families: array de ModelFamily strings
//   ['reasoning', 'vision', 'coding', 'instruction', 'fast', 'mini',
//    'multilingual', 'long-context']
//
// Pricing (nullable — solo OpenRouter lo devuelve en /models):
//   promptCostPer1kUsd      → costo por 1000 tokens de prompt en USD
//   completionCostPer1kUsd  → costo por 1000 tokens de completion en USD
//   Ejemplo: gpt-4o → prompt: 0.005, completion: 0.015

model ModelCatalogEntry {
  id          String   @id @default(cuid())

  providerId  String
  provider    ProviderCredential @relation(fields: [providerId], references: [id], onDelete: Cascade)

  modelId     String   // canónico: 'openai/gpt-4o', 'meta-llama/llama-3.3-70b'
  displayName String

  // Capacidades
  families    String[] // ModelFamily[]
  contextK    Int      @default(0)  // contexto en K tokens (0 = desconocido)

  // Pricing — null si el proveedor no lo devuelve (OpenAI, Anthropic)
  // Valor: USD por 1000 tokens
  promptCostPer1kUsd      Decimal? @db.Decimal(12, 8)
  completionCostPer1kUsd  Decimal? @db.Decimal(12, 8)

  isActive    Boolean  @default(true)
  raw         Json     @default("{}") // respuesta raw del proveedor (para debug)

  updatedAt   DateTime @updatedAt

  // Constraint: un modelo es único por proveedor
  @@unique([providerId, modelId])
  @@index([providerId])
  @@index([providerId, isActive])
  @@index([modelId])
}

// ── Run ───────────────────────────────────────────────────────────────────────
enum RunStatus {
  pending
  running
  paused
  completed
  failed
  cancelled
}

model Run {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  flowId      String?
  flow        Flow?     @relation(fields: [flowId], references: [id])
  agentId     String?
  agent       Agent?    @relation(fields: [agentId], references: [id])

  sessionId   String?
  // AUDIT-30: tipado con enum ChannelKind en lugar de String? libre
  channelKind ChannelKind?

  status      RunStatus @default(pending)
  inputData   Json      @default("{}")   // payload inicial
  outputData  Json?                      // resultado final
  error       String?
  metadata    Json      @default("{}")

  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  steps       RunStep[]
  costEvents  CostEvent[]

  @@index([workspaceId])
  @@index([agentId])
  @@index([flowId])
  @@index([status])
  @@index([createdAt])
}

// ── RunStep ───────────────────────────────────────────────────────────────────
enum RunStepStatus {
  pending
  running
  completed
  failed
  skipped
}

model RunStep {
  id        String        @id @default(cuid())
  runId     String
  run       Run           @relation(fields: [runId], references: [id], onDelete: Cascade)

  nodeId    String
  nodeType  String
  index     Int

  status    RunStepStatus @default(pending)
  input     Json          @default("{}")
  output    Json?
  error     String?

  model     String?
  provider  String?
  promptTokens     Int?
  completionTokens Int?
  totalTokens      Int?
  costUsd          Decimal? @db.Decimal(12, 8)

  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([runId])
  @@index([runId, index])
}

// ── ConversationMessage ────────────────────────────────────────────────────────
enum MessageRole {
  user
  assistant
  system
  tool
}

model ConversationMessage {
  id          String      @id @default(cuid())
  channelId   String
  channel     Channel     @relation(fields: [channelId], references: [id], onDelete: Cascade)

  sessionId   String
  role        MessageRole
  content     String      @db.Text
  toolName    String?
  toolCallId  String?
  metadata    Json        @default("{}")

  createdAt   DateTime    @default(now())

  @@index([channelId, sessionId])
  @@index([channelId, createdAt])
  @@index([sessionId])
}

// ── BudgetPolicy ──────────────────────────────────────────────────────────────
enum BudgetScope {
  workspace
  agent
  model
}

enum BudgetPeriod {
  daily
  weekly
  monthly
  total
}

model BudgetPolicy {
  id          String       @id @default(cuid())
  workspaceId String
  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  name        String
  scope       BudgetScope
  targetId    String?
  limitUsd    Decimal      @db.Decimal(10, 4)
  period      BudgetPeriod @default(monthly)
  periodDays  Int?
  enabled     Boolean      @default(true)
  alertPct    Int          @default(80)

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  incidents   BudgetIncident[]
  costEvents  CostEvent[]

  @@index([workspaceId])
  @@index([workspaceId, scope])
}

// ── BudgetIncident ────────────────────────────────────────────────────────────
enum IncidentKind {
  alert
  exceeded
  reset
}

model BudgetIncident {
  id             String       @id @default(cuid())
  budgetPolicyId String
  budgetPolicy   BudgetPolicy @relation(fields: [budgetPolicyId], references: [id], onDelete: Cascade)

  kind           IncidentKind
  usageUsd       Decimal      @db.Decimal(10, 4)
  limitUsd       Decimal      @db.Decimal(10, 4)
  pct            Int
  detail         Json         @default("{}")

  occurredAt     DateTime     @default(now())

  @@index([budgetPolicyId])
  @@index([occurredAt])
}

// ── CostEvent ─────────────────────────────────────────────────────────────────
model CostEvent {
  id             String        @id @default(cuid())
  runId          String?
  run            Run?          @relation(fields: [runId], references: [id])
  budgetPolicyId String?
  budgetPolicy   BudgetPolicy? @relation(fields: [budgetPolicyId], references: [id])

  provider       String
  model          String
  promptTokens   Int
  completionTokens Int
  totalTokens    Int
  costUsd        Decimal       @db.Decimal(12, 8)

  agentId        String?
  workspaceId    String?
  metadata       Json          @default("{}")

  createdAt      DateTime      @default(now())

  @@index([runId])
  @@index([budgetPolicyId])
  @@index([workspaceId, createdAt])
  @@index([agentId, createdAt])
  @@index([provider, model, createdAt])
}

// ── ModelPolicy ───────────────────────────────────────────────────────────────
enum ModelPolicyScope {
  workspace
  agent
  flow_node
}

model ModelPolicy {
  id          String           @id @default(cuid())
  workspaceId String
  workspace   Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  scope       ModelPolicyScope
  targetId    String?
  agent       Agent?           @relation(fields: [targetId], references: [id])

  provider    String
  model       String
  temperature Decimal          @default(0.7) @db.Decimal(3, 2)
  maxTokens   Int              @default(4096)
  topP        Decimal          @default(1.0) @db.Decimal(3, 2)
  config      Json             @default("{}")
  enabled     Boolean          @default(true)

  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([workspaceId, scope, targetId])
  @@index([workspaceId])
  @@index([workspaceId, scope])
}

// ── AgentProfile ──────────────────────────────────────────────────────────────
model AgentProfile {
  id          String   @id @default(cuid())
  agentId     String   @unique
  agent       Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)

  systemPrompt     String?  @db.Text
  persona          Json     @default("{}")
  knowledgeBase    Json     @default("[]")
  responseFormat   String?
  contextWindow    Int      @default(8192)
  memoryEnabled    Boolean  @default(false)
  memoryConfig     Json     @default("{}")

  version      Int      @default(1)
  propagatedAt DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ── Approval ──────────────────────────────────────────────────────────────────
enum ApprovalStatus {
  pending
  approved
  rejected
  expired
}

model Approval {
  id          String         @id @default(cuid())
  workspaceId String
  workspace   Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  agentId     String?
  agent       Agent?         @relation(fields: [agentId], references: [id])

  runId       String?
  stepId      String?

  status      ApprovalStatus @default(pending)
  title       String
  description String?        @db.Text
  payload     Json           @default("{}")
  reviewedBy  String?
  reviewNote  String?        @db.Text
  expiresAt   DateTime?

  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([workspaceId, status])
  @@index([runId])
}

// ── ActivityLog ───────────────────────────────────────────────────────────────
enum ActivityResource {
  workspace
  agent
  flow
  skill
  policy
  channel
  run
  budget
  model_policy
  approval
}

model ActivityLog {
  id          String           @id @default(cuid())
  workspaceId String?
  workspace   Workspace?       @relation(fields: [workspaceId], references: [id])

  resource    ActivityResource
  resourceId  String?
  action      String
  detail      String           @db.Text
  userId      String?
  metadata    Json             @default("{}")

  createdAt   DateTime         @default(now())

  @@index([workspaceId, createdAt])
  @@index([resource, resourceId])
  @@index([createdAt])
}
