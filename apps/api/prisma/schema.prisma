// ESTE ARCHIVO ES UN REDIRECT — NO EDITAR AQUÍ
//
// El schema canónico de Prisma está en:
//   packages/db/prisma/schema.prisma
//
// Este archivo existe sólo para compatibilidad con herramientas que
// buscan el schema en apps/api/prisma/ (Prisma Studio, algunos IDE plugins).
//
// FUENTE Única de verdad:
//   packages/db/prisma/schema.prisma  (v9 — schema fusionado)
//
// Para regenerar el cliente:
//   npx prisma generate --schema=packages/db/prisma/schema.prisma
//
// Para migraciones:
//   npx prisma migrate dev --schema=packages/db/prisma/schema.prisma
// ──────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

