{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "experimentalDecorators":  true,
    "emitDecoratorMetadata":   true,
    "outDir":                  "dist",
    "rootDir":                 "src",
    "baseUrl":                 ".",
    "paths": {
      "@gateway/*": ["src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "**/*.spec.ts", "**/*.test.ts"]
}
