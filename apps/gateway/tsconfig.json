{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite":               true,
    "experimentalDecorators":  true,
    "emitDecoratorMetadata":   true,
    "outDir":                  "dist",
    "rootDir":                 "src",
    "baseUrl":                 ".",
    "paths": {
      "@gateway/*":             ["src/*"],
      "@agent-vs/gateway-sdk":  ["src/index.ts"],
      "@agent-vs/flow-engine":  ["src/stubs/flow-engine.stub.ts"],
      "@lss/crypto":            ["src/stubs/crypto.stub.ts"]
    }
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.spec.ts",
    "**/*.test.ts",
    "**/*.e2e-spec.ts",
    "**/__tests__/**",
    "src/tests/**"
  ]
}
