// ─────────────────────────────────────────────────────────────────────────────
// prisma/schema.prisma
// Agent Visual Studio — Full Platform Schema
//
// Hierarchy:    Agency → Department → Workspace → Agent → Subagent
// Execution:    Flow → Run → RunStep  (LangGraph-style checkpoints)
// Gateway:      ChannelConfig → ChannelBinding → GatewaySession
// Integrations: N8nConnection → N8nWorkflow
// Providers:    ProviderCredential → ModelCatalogEntry
// Policies:     BudgetPolicy, ModelPolicy  (scope-inherited, exactly-one-FK)
// Audit:        AuditEvent
//
// ── ProviderCredential ───────────────────────────────────────────────────────
// Almacena credenciales de proveedores LLM configurados por el tenant.
// Reemplaza las env vars OPENAI_API_KEY / ANTHROPIC_API_KEY / OPENROUTER_API_KEY.
// La API key se cifra con AES-256-GCM usando PROVIDER_SECRET (env var).
// El campo `type` determina el routing en ProviderCatalogService y callLLM():
//   'openai'       → api.openai.com/v1
//   'anthropic'    → api.anthropic.com/v1/messages
//   'openrouter'   → openrouter.ai/api/v1  (cubre 50+ proveedores)
//   'openai_compat'→ baseUrl personalizada con protocolo OpenAI-compat
//
// ── ModelCatalogEntry ────────────────────────────────────────────────────────
// Cache de modelos disponibles, sincronizados desde las APIs de cada proveedor.
// ProviderCatalogService.sync() llama /models de cada ProviderCredential activo
// y upserta los resultados enriquecidos con families del CAPABILITY_REGISTRY seed.
//
// ── ModelPolicy.fallbackChain ────────────────────────────────────────────────
// String[] reemplaza fallbackModel String?.
// Permite lista ordenada de fallbacks de libre elección entre cualquier modelo
// del catálogo activo, de cualquier proveedor configurado.
//
// ── Exactly-one-FK invariant on Policy tables ────────────────────────────────
// BudgetPolicy and ModelPolicy each belong to exactly ONE scope level
// (agency | department | workspace | agent). Enforced at two layers:
//
//   1. DB layer — raw CHECK constraint added via a manual migration:
//      ALTER TABLE "BudgetPolicy" ADD CONSTRAINT "budget_policy_exactly_one_scope"
//        CHECK (
//          (CASE WHEN "agencyId"     IS NOT NULL THEN 1 ELSE 0 END +
//           CASE WHEN "departmentId" IS NOT NULL THEN 1 ELSE 0 END +
//           CASE WHEN "workspaceId"  IS NOT NULL THEN 1 ELSE 0 END +
//           CASE WHEN "agentId"      IS NOT NULL THEN 1 ELSE 0 END) = 1
//        );
//      (Same for "ModelPolicy". See prisma/migrations/README.md.)
//
//   2. App layer — PolicyScopeGuard in apps/api validates before upsert.
//      Import: import { assertExactlyOneScope } from '@agent-vs/core-types';
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Scope enum (used by app-layer validation, NOT a Prisma enum in DB) ───────
// Values: 'agency' | 'department' | 'workspace' | 'agent'
// Kept as String fields in the DB so we can extend without migrations.

// ─── Hierarchy ────────────────────────────────────────────────────────────────

model Agency {
  id           String       @id @default(uuid())
  name         String
  slug         String       @unique
  /// Orchestrator system prompt — auto-updated by ProfilePropagatorService
  systemPrompt String?      @db.Text
  model        String       @default("openai/gpt-4o")
  /// Aggregated capability profile (JSON) — built by AgentBuilder
  profileJson  Json?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  departments         Department[]
  runs                Run[]
  budgetPolicy        BudgetPolicy?        @relation("AgencyBudget")
  modelPolicy         ModelPolicy?         @relation("AgencyModel")
  providerCredentials ProviderCredential[]
}

model Department {
  id           String      @id @default(uuid())
  agencyId     String
  agency       Agency      @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  name         String
  slug         String
  systemPrompt String?     @db.Text
  model        String      @default("openai/gpt-4o")
  profileJson  Json?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  workspaces   Workspace[]
  budgetPolicy BudgetPolicy? @relation("DepartmentBudget")
  modelPolicy  ModelPolicy?  @relation("DepartmentModel")

  @@unique([agencyId, slug])
}

model Workspace {
  id           String     @id @default(uuid())
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  name         String
  slug         String
  systemPrompt String?    @db.Text
  model        String     @default("openai/gpt-4o")
  profileJson  Json?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  agents       Agent[]
  budgetPolicy BudgetPolicy? @relation("WorkspaceBudget")
  modelPolicy  ModelPolicy?  @relation("WorkspaceModel")

  @@unique([departmentId, slug])
}

model Agent {
  id           String    @id @default(uuid())
  workspaceId  String
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name         String
  slug         String
  /// 'orchestrator' | 'specialist' | 'subagent'
  role         String    @default("specialist")
  systemPrompt String?   @db.Text
  model        String    @default("openai/gpt-4o")
  profileJson  Json?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  skills          AgentSkill[]
  channelBindings ChannelBinding[]
  flows           Flow[]
  subagents       Subagent[]
  budgetPolicy    BudgetPolicy? @relation("AgentBudget")
  modelPolicy     ModelPolicy?  @relation("AgentModel")

  @@unique([workspaceId, slug])
}

model Subagent {
  id           String   @id @default(uuid())
  agentId      String
  agent        Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  name         String
  slug         String
  systemPrompt String?  @db.Text
  model        String   @default("openai/gpt-4o")
  profileJson  Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  skills       SubagentSkill[]

  @@unique([agentId, slug])
}

// ─── Skills / Tools ──────────────────────────────────────────────────────────

model Skill {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?  @db.Text
  /// 'mcp' | 'builtin' | 'n8n_webhook' | 'openapi' | 'function'
  type        String
  /// For mcp:         { command, args, env }
  /// For n8n_webhook: { webhookUrl, method }
  /// For openapi:     { specUrl, operationId }
  /// For function:    { handler (serialized) }
  config      Json
  /// JSON Schema of expected input
  schema      Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  agents    AgentSkill[]
  subagents SubagentSkill[]
}

model AgentSkill {
  agentId String
  skillId String
  agent   Agent  @relation(fields: [agentId], references: [id], onDelete: Cascade)
  skill   Skill  @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([agentId, skillId])
}

model SubagentSkill {
  subagentId String
  skillId    String
  subagent   Subagent @relation(fields: [subagentId], references: [id], onDelete: Cascade)
  skill      Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([subagentId, skillId])
}

// ─── Flows ───────────────────────────────────────────────────────────────────

model Flow {
  id          String   @id @default(uuid())
  agentId     String
  agent       Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  name        String
  description String?
  /// Serialized FlowSpec — { nodes: FlowNode[], edges: FlowEdge[] }
  spec        Json
  version     Int      @default(1)
  isActive    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  runs Run[]
}

// ─── Runs ────────────────────────────────────────────────────────────────────

model Run {
  id           String    @id @default(uuid())
  flowId       String
  flow         Flow      @relation(fields: [flowId], references: [id])
  agencyId     String?
  agency       Agency?   @relation(fields: [agencyId], references: [id])
  /// 'queued' | 'running' | 'completed' | 'failed' | 'cancelled' | 'waiting_approval'
  status       String    @default("queued")
  /// { type: 'manual' | 'channel' | 'schedule' | 'replay:<runId>', payload? }
  trigger      Json
  error        String?   @db.Text
  startedAt    DateTime  @default(now())
  completedAt  DateTime?
  /// Accumulated cost for the whole run (sum of RunStep.costUsd)
  totalCostUsd Float     @default(0)
  metadata     Json?
  createdAt    DateTime  @default(now())

  steps RunStep[]

  @@index([flowId, status])
  @@index([agencyId, createdAt])
}

model RunStep {
  id          String    @id @default(uuid())
  runId       String
  run         Run       @relation(fields: [runId], references: [id], onDelete: Cascade)
  /// Matches FlowNode.id in the flow spec
  nodeId      String
  /// 'agent' | 'tool' | 'condition' | 'loop' | 'approval' | 'input' | 'output'
  nodeType    String
  agentId     String?
  /// 'queued' | 'running' | 'completed' | 'failed' | 'skipped' | 'waiting_approval'
  status      String    @default("queued")
  input       Json?
  output      Json?
  error       String?   @db.Text
  /// { input: number, output: number }
  tokenUsage  Json?
  costUsd     Float     @default(0)
  retryCount  Int       @default(0)
  startedAt   DateTime  @default(now())
  completedAt DateTime?

  @@index([runId, nodeId])
}

// ─── Gateway / Channels ──────────────────────────────────────────────────────

model ChannelConfig {
  id               String  @id @default(uuid())
  /// 'telegram' | 'whatsapp' | 'webchat' | 'slack' | 'discord' | 'webhook'
  type             String
  name             String
  /// AES-256-GCM encrypted secrets (CHANNEL_SECRET env key)
  secretsEncrypted String   @db.Text
  /// Non-sensitive config: { webhookPath, parseMode, allowedOrigins, ... }
  config           Json
  isActive         Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  bindings ChannelBinding[]
  sessions GatewaySession[]
}

model ChannelBinding {
  id              String        @id @default(uuid())
  channelConfigId String
  channelConfig   ChannelConfig @relation(fields: [channelConfigId], references: [id], onDelete: Cascade)
  agentId         String
  agent           Agent         @relation(fields: [agentId], references: [id], onDelete: Cascade)
  /// Level that owns this binding: 'agency' | 'department' | 'workspace' | 'agent'
  scopeLevel      String        @default("agent")
  /// ID of the scope entity (agencyId, departmentId, etc.)
  scopeId         String
  isDefault       Boolean       @default(false)
  createdAt       DateTime      @default(now())

  @@unique([channelConfigId, agentId])
}

model GatewaySession {
  id              String        @id @default(uuid())
  channelConfigId String
  channelConfig   ChannelConfig @relation(fields: [channelConfigId], references: [id])
  /// External user ID in the channel (Telegram chat_id, WhatsApp phone, etc.)
  externalUserId  String
  agentId         String
  /// Conversation message history — [{ role, content, ts }]
  messageHistory  Json          @default("[]")
  /// 'active' | 'paused' | 'closed'
  state           String        @default("active")
  metadata        Json?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([channelConfigId, externalUserId])
  @@index([agentId, state])
}

// ─── n8n Integration ─────────────────────────────────────────────────────────

model N8nConnection {
  id              String   @id @default(uuid())
  name            String   @default("default")
  /// Base URL of the n8n instance, e.g. https://n8n.example.com
  baseUrl         String
  apiKeyEncrypted String   @db.Text
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  workflows N8nWorkflow[]
}

model N8nWorkflow {
  id            String        @id @default(uuid())
  connectionId  String
  connection    N8nConnection @relation(fields: [connectionId], references: [id])
  /// Workflow ID as it exists inside n8n
  n8nWorkflowId String
  name          String
  description   String?
  /// JSON Schema of parameters exposed to skills
  inputSchema   Json?
  webhookUrl    String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([connectionId, n8nWorkflowId])
}

// ─── Provider Credentials ────────────────────────────────────────────────────
//
// Almacena proveedores LLM configurados por la agencia (tenant).
// Reemplaza OPENAI_API_KEY / ANTHROPIC_API_KEY / OPENROUTER_API_KEY como
// env vars hardcodeadas — la API key vive en DB cifrada con AES-256-GCM
// usando la env var PROVIDER_SECRET como clave maestra.
//
// type:
//   'openai'        → https://api.openai.com/v1  (Authorization: Bearer)
//   'anthropic'     → https://api.anthropic.com/v1  (x-api-key header)
//   'openrouter'    → https://openrouter.ai/api/v1  (Bearer, cubre 50+ proveedores)
//   'openai_compat' → baseUrl personalizada con protocolo OpenAI Chat Completions
//
// extraHeaders: Json opcional — headers adicionales enviados en cada request
//   ej: { "HTTP-Referer": "https://app.example.com", "X-Title": "My App" }
//   (útil para OpenRouter site tracking)
//
// syncedAt: timestamp del último sync exitoso de ModelCatalogEntry desde este proveedor.
//   null = nunca sincronizado.

model ProviderCredential {
  id               String    @id @default(uuid())
  agencyId         String
  agency           Agency    @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  /// Human-readable name, ej: "OpenAI Production", "OpenRouter via LSS"
  name             String
  /// 'openai' | 'anthropic' | 'openrouter' | 'openai_compat'
  type             String
  /// Base URL — obligatorio para 'openai_compat', ignorado para 'openai' y 'anthropic'
  /// Para 'openrouter' puede omitirse (default: https://openrouter.ai/api/v1)
  baseUrl          String?
  /// AES-256-GCM encrypted API key. Clave maestra: env PROVIDER_SECRET
  apiKeyEncrypted  String    @db.Text
  /// Headers adicionales en Json: { "HTTP-Referer": "...", "X-Title": "..." }
  extraHeaders     Json?
  isActive         Boolean   @default(true)
  /// Timestamp del último sync exitoso de catálogo desde este proveedor
  syncedAt         DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  catalogEntries ModelCatalogEntry[]

  @@unique([agencyId, name])
  @@index([agencyId, type, isActive])
}

// ─── Model Catalog ────────────────────────────────────────────────────────────
//
// Cache de modelos disponibles sincronizados desde las APIs de cada proveedor.
// ProviderCatalogService.sync(providerId) llama:
//   - OpenAI:      GET /v1/models
//   - Anthropic:   GET /v1/models
//   - OpenRouter:  GET /v1/models  (devuelve todos los providers con metadata rica)
//   - openai_compat: GET /v1/models (si el endpoint existe)
//
// families: String[] — tags de capacidad asignados automáticamente.
//   Fuente primaria: metadata del proveedor (OpenRouter incluye context_length,
//   architecture.modality, etc.).
//   Fuente secundaria: CAPABILITY_REGISTRY seed en model-capability-registry.ts,
//   usado para enriquecer cuando el proveedor no devuelve families.
//
// contextK: ventana de contexto en miles de tokens (0 = desconocido).
//
// isActive: true si el proveedor devolvió este modelo en el último sync.
//   false = modelo retirado pero conservado en historial.
//
// raw: respuesta original del proveedor (para audit y enriquecimiento futuro).

model ModelCatalogEntry {
  id           String             @id @default(uuid())
  providerId   String
  provider     ProviderCredential @relation(fields: [providerId], references: [id], onDelete: Cascade)
  /// Canónico: 'provider/model-name' — mismo formato que ModelPolicy.primaryModel
  /// Para openrouter el modelId incluye el sub-provider: 'meta-llama/llama-3.3-70b-instruct'
  modelId      String
  /// Display name del modelo (del proveedor)
  displayName  String
  /// Familias de capacidad: ['reasoning','fast','vision','coding','multilingual','long-context','instruction','mini']
  families     String[]
  /// Contexto máximo en miles de tokens (0 = desconocido)
  contextK     Int                @default(0)
  /// true si el proveedor devolvió este modelo en el último sync
  isActive     Boolean            @default(true)
  /// Respuesta original del proveedor para audit
  raw          Json?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@unique([providerId, modelId])
  @@index([providerId, isActive])
  @@index([modelId])
}

// ─── Budget / Model Policies ─────────────────────────────────────────────────
//
// INVARIANT: exactly one FK is non-null per row.
//
// Prisma @unique prevents two policies at the same scope, but cannot prevent:
//   (a) a row with ALL FKs null, or
//   (b) a row with MORE THAN ONE FK set.
//
// Both cases are blocked by the CHECK constraints documented at the top of
// this file. Run `npx prisma migrate dev --name add_policy_scope_check` then
// edit the generated SQL file to add the constraints before applying.
//
// Resolution order at runtime: agent → workspace → department → agency
// See: packages/run-engine/src/policy-resolver.ts
//
// ModelPolicy.fallbackChain: String[] (lista ordenada de modelos de fallback)
//   Reemplaza fallbackModel String? del schema anterior.
//   Cada elemento es un modelId canónico ('provider/model-name') de libre
//   elección entre los modelos activos en ModelCatalogEntry.
//   OrchestratorModelResolver itera la cadena en orden hasta que un modelo
//   responde exitosamente; si todos fallan → template estático.

model BudgetPolicy {
  id         String   @id @default(uuid())
  /// Rolling window spend limit in USD
  limitUsd   Float
  /// Window length in days (default: 30)
  periodDays Int      @default(30)
  /// Alert threshold as fraction of limitUsd (default: 0.8 = 80%)
  alertAt    Float    @default(0.8)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // ── Scope FKs — exactly one must be non-null (enforced by DB CHECK) ──────
  agencyId     String? @unique
  departmentId String? @unique
  workspaceId  String? @unique
  agentId      String? @unique

  agency     Agency?     @relation("AgencyBudget",     fields: [agencyId],     references: [id], onDelete: Cascade)
  department Department? @relation("DepartmentBudget", fields: [departmentId], references: [id], onDelete: Cascade)
  workspace  Workspace?  @relation("WorkspaceBudget",  fields: [workspaceId],  references: [id], onDelete: Cascade)
  agent      Agent?      @relation("AgentBudget",      fields: [agentId],      references: [id], onDelete: Cascade)
}

model ModelPolicy {
  id            String   @id @default(uuid())
  /// Modelo principal: 'provider/model-name' — debe existir en ModelCatalogEntry
  primaryModel  String
  /// Cadena ordenada de fallbacks de libre elección.
  /// Cada elemento es un modelId canónico activo en ModelCatalogEntry.
  /// Reemplaza fallbackModel String? — ahora admite N fallbacks de cualquier proveedor.
  fallbackChain String[]
  temperature   Float?   @default(0.7)
  maxTokens     Int?     @default(4096)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // ── Scope FKs — exactly one must be non-null (enforced by DB CHECK) ──────
  agencyId     String? @unique
  departmentId String? @unique
  workspaceId  String? @unique
  agentId      String? @unique

  agency     Agency?     @relation("AgencyModel",     fields: [agencyId],     references: [id], onDelete: Cascade)
  department Department? @relation("DepartmentModel", fields: [departmentId], references: [id], onDelete: Cascade)
  workspace  Workspace?  @relation("WorkspaceModel",  fields: [workspaceId],  references: [id], onDelete: Cascade)
  agent      Agent?      @relation("AgentModel",      fields: [agentId],      references: [id], onDelete: Cascade)
}

// ─── Audit ───────────────────────────────────────────────────────────────────

model AuditEvent {
  id        String   @id @default(uuid())
  /// e.g. 'run.started' | 'run.completed' | 'agent.created' | 'channel.message' | 'budget.alert'
  eventType String
  /// Entity kind: 'agency' | 'department' | 'workspace' | 'agent' | 'run' | 'channel'
  scopeType String?
  scopeId   String?
  /// Logto user ID (if triggered by a user action via Studio)
  userId    String?
  payload   Json
  createdAt DateTime @default(now())

  @@index([eventType, createdAt])
  @@index([scopeType, scopeId, createdAt])
  @@index([userId, createdAt])
}
