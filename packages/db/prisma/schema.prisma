// ============================================================
// schema.prisma — Agent Visual Studio
// Multi-tenant: Agency → Department → Workspace → Agent
// Durable execution: Run → RunStep con checkpointData
// Credenciales de modelos y canales: cifradas en DB (NO en .env)
//
// v3 — ProfilePropagatorService:
//   + AgentProfile (system prompt, persona, knowledge base, memory config)
//   + Agent.goal + Agent.backstory (usados por ProfilePropagatorService.buildFallbackPrompt)
// ============================================================

generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ────────────────────────────────────────────────────────────
// MULTI-TENANT HIERARCHY
// ────────────────────────────────────────────────────────────

model Agency {
  id          String       @id @default(cuid())
  name        String
  slug        String       @unique
  plan        String       @default("free") // free | pro | enterprise
  metadata    Json?        @default("{}")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  departments  Department[]
  budgetPolicy BudgetPolicy[]
  activityLogs ActivityLog[]

  @@map("agencies")
}

model Department {
  id         String      @id @default(cuid())
  agencyId   String
  name       String
  slug       String
  metadata   Json?       @default("{}")
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  agency       Agency        @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  workspaces   Workspace[]
  budgetPolicy BudgetPolicy[]
  activityLogs ActivityLog[]

  @@unique([agencyId, slug])
  @@map("departments")
}

model Workspace {
  id           String    @id @default(cuid())
  departmentId String
  name         String
  slug         String
  // Effective model policy stored as JSON (provider, model, maxTokens, temperature…)
  modelPolicy  Json?     @default("{}")
  metadata     Json?     @default("{}")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  department     Department       @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  agents         Agent[]
  flows          Flow[]
  runs           Run[]
  channelConfigs ChannelConfig[]
  budgetPolicy   BudgetPolicy[]
  routines       Routine[]
  activityLogs   ActivityLog[]

  @@unique([departmentId, slug])
  @@map("workspaces")
}

// ────────────────────────────────────────────────────────────
// AGENTS
// ────────────────────────────────────────────────────────────

model Agent {
  id              String   @id @default(cuid())
  workspaceId     String
  name            String
  role            String
  description     String   @default("")
  instructions    String   @default("")

  // ── Nuevos campos v3 (ProfilePropagatorService) ───────────────────
  // goal: objetivo principal del agente (usado en system prompt fallback)
  goal            String?  @default("")
  // backstory: contexto narrativo del agente (opcional)
  backstory       String?  @default("")

  model           String   @default("gpt-4o-mini")
  tags            String[] @default([])
  visibility      String   @default("private")   // private | workspace | public
  executionMode   String   @default("direct")    // direct | orchestrated | handoff
  kind            String   @default("agent")     // agent | subagent | orchestrator
  parentAgentId   String?
  context         String[] @default([])
  // JSON blobs for flexible config (triggers, permissions, handoffRules, channelBindings, policyBindings)
  triggers        Json?    @default("[]")
  permissions     Json?    @default("{}")
  handoffRules    Json?    @default("[]")
  channelBindings Json?    @default("[]")
  policyBindings  Json?    @default("[]")
  isEnabled       Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  workspace             Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  parent                Agent?                @relation("AgentHierarchy", fields: [parentAgentId], references: [id])
  subagents             Agent[]               @relation("AgentHierarchy")
  skillLinks            AgentSkill[]
  runSteps              RunStep[]
  channelBindingRecords ChannelBinding[]
  gatewaySessions       GatewaySession[]
  wakeupRequests        AgentWakeupRequest[]
  budgetPolicy          BudgetPolicy[]
  activityLogs          ActivityLog[]
  // 1-to-1 con AgentProfile (puede ser null si no se ha propagado)
  agentProfile          AgentProfile?

  @@index([workspaceId])
  @@map("agents")
}

// ────────────────────────────────────────────────────────────
// AGENT PROFILE — v3 (ProfilePropagatorService)
//
// Un registro por agente (1-to-1 con Agent).
// Creado/actualizado por ProfilePropagatorService.propagate().
//
// Separado de Agent para:
//   1. Mantener Agent como entidad ligera de configuración estructural
//   2. Permitir versioning del perfil sin tocar el agente
//   3. Cargar el perfil solo cuando el LLM lo necesita (lazy)
// ────────────────────────────────────────────────────────────

model AgentProfile {
  id              String   @id @default(cuid())
  agentId         String   @unique  // 1-to-1 con Agent

  // System prompt explícito (escrito por el builder o el admin).
  // Si está presente, ProfilePropagatorService lo usa directamente.
  // Si es null/empty, buildSystemPrompt() genera desde persona + rol + goal.
  systemPrompt    String?  @db.Text

  // Persona del agente: tone, language, traits, name de presentación
  // Estructura: { name?, tone?, language?, traits?: string[] }
  persona         Json     @default("{}")

  // Knowledge base: URLs, textos, referencias de documentos
  // Estructura: Array<{ type: 'url'|'text'|'file', label: string, value: string }>
  knowledgeBase   Json     @default("[]")

  // Formato esperado de respuesta del LLM
  responseFormat  String?  // null | 'json' | 'markdown' | 'plain'

  // Ventana de contexto máxima en tokens (para este agente)
  contextWindow   Int      @default(8192)

  // Si el agente usa memoria persistente entre sesiones (future)
  memoryEnabled   Boolean  @default(false)
  // Config de memoria: { provider, connectionString, topK, ... }
  memoryConfig    Json     @default("{}")

  // Control de versiones del perfil
  version         Int      @default(1)
  propagatedAt    DateTime @default(now())  // última vez que se propagó

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([agentId])
  @@map("agent_profiles")
}

// ────────────────────────────────────────────────────────────
// SKILLS
// ────────────────────────────────────────────────────────────

model Skill {
  id           String   @id @default(cuid())
  name         String
  description  String   @default("")
  version      String   @default("1.0.0")
  // mcp | openapi | n8n_webhook | builtin | function | plugin
  type         String   @default("builtin")
  category     String   @default("general")
  permissions  String[] @default([])
  // functions[], plugin, files, dependencies stored as JSON
  functions    Json?    @default("[]")
  plugin       Json?
  // Para type=openapi: spec URL o spec inline
  openapiSpec  Json?
  // Para type=mcp: server URL y capabilities
  mcpConfig    Json?
  // Para type=n8n_webhook: webhook URL y auth
  n8nConfig    Json?
  files        String[] @default([])
  dependencies String[] @default([])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  agentLinks AgentSkill[]

  @@map("skills")
}

// Junction table Agent ↔ Skill
model AgentSkill {
  agentId   String
  skillId   String
  addedAt   DateTime @default(now())

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)
  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([agentId, skillId])
  @@map("agent_skills")
}

// ────────────────────────────────────────────────────────────
// FLOWS
// ────────────────────────────────────────────────────────────

model Flow {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  description String?  @default("")
  version     String?  @default("1.0.0")
  trigger     String   @default("manual")
  // nodes[] and edges[] stored as JSON (FlowNode[], FlowEdge[])
  nodes       Json?    @default("[]")
  edges       Json?    @default("[]")
  tags        String[] @default([])
  isEnabled   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  runs      Run[]

  @@index([workspaceId])
  @@map("flows")
}

// ────────────────────────────────────────────────────────────
// RUNS — durable execution
// ────────────────────────────────────────────────────────────

model Run {
  id          String   @id @default(cuid())
  workspaceId String
  flowId      String
  status      String   @default("queued") // queued | running | waiting_approval | completed | failed | cancelled
  // trigger stored as JSON (RunTrigger)
  trigger     Json     @default("{}")
  error       String?
  metadata    Json?    @default("{}")
  startedAt   DateTime @default(now())
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace      Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  flow           Flow                 @relation(fields: [flowId], references: [id], onDelete: Cascade)
  steps          RunStep[]
  approvals      Approval[]
  wakeupRequests AgentWakeupRequest[]
  costEvents     CostEvent[]

  @@index([workspaceId, status])
  @@index([flowId])
  @@map("runs")
}

model RunStep {
  id          String   @id @default(cuid())
  runId       String
  nodeId      String
  nodeType    String
  status      String   @default("queued") // queued | running | waiting_approval | completed | failed | skipped
  agentId     String?
  // input/output as JSON
  input       Json?    @default("{}")
  output      Json?    @default("{}")
  error       String?
  retryCount  Int      @default(0)
  tokenInput  Int      @default(0)
  tokenOutput Int      @default(0)
  costUsd     Float    @default(0)
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // ── Durable execution fields ──────────────────────────────
  // Snapshot del estado del step para reanudar tras crash/restart
  checkpointData   Json?    // messages[], tool_calls[], observations[]
  checkpointSeq    Int      @default(0) // iteración del loop ReAct
  interruptReason  String?  // human_approval | budget_exceeded | tool_error | max_iter
  resumePayload    Json?    // datos inyectados al resumir (aprobación humana, corrección, etc.)
  durableState     String   @default("none") // none | paused | resuming | replaying

  run        Run       @relation(fields: [runId], references: [id], onDelete: Cascade)
  agent      Agent?    @relation(fields: [agentId], references: [id])
  approvals  Approval[]
  costEvents CostEvent[]
  wakeupRequests AgentWakeupRequest[]

  @@index([runId])
  @@index([agentId])
  @@map("run_steps")
}

// ────────────────────────────────────────────────────────────
// CHANNELS — gateway multi-canal
// ────────────────────────────────────────────────────────────

// Configuración de un canal (WhatsApp, Telegram, Slack, Email…)
// IMPORTANTE: credentials se cifran en la aplicación antes de guardar
model ChannelConfig {
  id          String   @id @default(cuid())
  workspaceId String
  channel     String   // whatsapp | telegram | slack | email | web | custom
  displayName String
  // credentials CIFRADAS (AES-256-GCM) — nunca texto plano
  credentials Json     @default("{}")
  settings    Json?    @default("{}")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  bindings  ChannelBinding[]
  sessions  GatewaySession[]

  @@unique([workspaceId, channel])
  @@map("channel_configs")
}

// Binding canal ↔ agente (un agente puede atender múltiples rutas)
model ChannelBinding {
  id              String   @id @default(cuid())
  channelConfigId String
  agentId         String
  route           String   // número, room, thread prefix, etc.
  isEnabled       Boolean  @default(true)
  createdAt       DateTime @default(now())

  channelConfig ChannelConfig @relation(fields: [channelConfigId], references: [id], onDelete: Cascade)
  agent         Agent         @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([channelConfigId, route])
  @@map("channel_bindings")
}

// ────────────────────────────────────────────────────────────
// GATEWAY SESSION + CONVERSATION MESSAGES
//
// Patrón anti-TOAST (inspirado en LangGraph Thread pattern):
//   GatewaySession.activeContextJson  → ventana compacta para el LLM (<3KB)
//                                        se reescribe con summarización
//   ConversationMessage               → historial permanente, append-only,
//                                        queryable, auditable por mensaje
//
// SessionManager resuelve GatewaySession vía (channelConfigId, externalId)
// y usa session.id como FK en ConversationMessage.
// ────────────────────────────────────────────────────────────

model GatewaySession {
  id              String   @id @default(cuid())
  channelConfigId String
  externalId      String   // user ID / thread ID del canal
  agentId         String

  // Ventana activa para el LLM: últimos N msgs + resumen. Siempre pequeño (<3KB).
  // Se compacta con summarización cuando el historial crece.
  // NO es el historial completo — eso vive en ConversationMessage.
  activeContextJson Json?  @default("[]")

  state          String   @default("active") // active | idle | closed
  lastActivityAt DateTime @default(now())
  metadata       Json?    @default("{}")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  channelConfig ChannelConfig        @relation(fields: [channelConfigId], references: [id], onDelete: Cascade)
  agent         Agent                @relation(fields: [agentId], references: [id])
  messages      ConversationMessage[]

  @@unique([channelConfigId, externalId])
  @@index([agentId])
  @@map("gateway_sessions")
}

// Historial permanente de conversación — append-only, nunca updates
// Cada registro es un mensaje individual (~1KB JSONB — seguro anti-TOAST)
model ConversationMessage {
  id               String   @id @default(cuid())
  sessionId        String
  role             String   // user | assistant | system | tool

  // contentText: texto plano para búsqueda full-text y visualización
  contentText      String?  @db.Text
  // contentJson: estructura completa OpenAI-compatible:
  //   user/assistant: [{ type: 'text', text: string }]
  //   tool:           [{ type: 'tool_result', tool_use_id, content }]
  //   system:         string
  contentJson      Json     // estructura completa

  channelMessageId String?  // ID externo del canal (Telegram msg_id, etc.)
  toolCallId       String?  // si es resultado de un tool call
  toolName         String?

  // Scope jerárquico del agente que respondió o recibió
  scopeType        String?  // agency | department | workspace | agent
  scopeId          String?

  tokenCount       Int?     // tokens del mensaje (estimado o real)
  createdAt        DateTime @default(now())

  session GatewaySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@index([sessionId, role])
  @@index([scopeId, createdAt])
  @@map("conversation_messages")
}

// ────────────────────────────────────────────────────────────
// BUDGET GOVERNANCE
// ────────────────────────────────────────────────────────────

model BudgetPolicy {
  id                  String   @id @default(cuid())
  scopeType           String   // agency | department | workspace | agent
  scopeId             String
  window              String   @default("monthly") // daily | weekly | monthly | custom

  softCapUsd          Float?
  hardCapUsd          Float?
  requireApproval     Boolean  @default(false)
  approvalThreshold   Float?
  replayBudgetUsd     Float?
  escalationThreshold Float?

  perModelCaps        Json?    @default("{}")

  inheritedFrom       String?
  effectiveValue      Json?
  isOverride          Boolean  @default(false)

  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  agency     Agency?     @relation(fields: [scopeId], references: [id])
  department Department? @relation(fields: [scopeId], references: [id])
  workspace  Workspace?  @relation(fields: [scopeId], references: [id])
  agent      Agent?      @relation(fields: [scopeId], references: [id])
  incidents  BudgetIncident[]

  @@unique([scopeType, scopeId, window])
  @@index([scopeId])
  @@map("budget_policies")
}

model BudgetIncident {
  id           String   @id @default(cuid())
  policyId     String
  scopeType    String
  scopeId      String
  incidentType String   // soft_cap_reached | hard_cap_reached | approval_required | per_model_cap_reached
  triggeredAt  DateTime @default(now())
  resolvedAt   DateTime?
  runId        String?
  runStepId    String?
  amountUsd    Float
  metadata     Json?    @default("{}")

  policy BudgetPolicy @relation(fields: [policyId], references: [id])

  @@index([scopeId, triggeredAt])
  @@index([policyId])
  @@map("budget_incidents")
}

// ────────────────────────────────────────────────────────────
// COST EVENTS
// ────────────────────────────────────────────────────────────

model CostEvent {
  id            String   @id @default(cuid())
  runStepId     String?
  runId         String?
  agentId       String?
  scopeType     String
  scopeId       String
  model         String
  provider      String   @default("openai")
  promptTokens  Int      @default(0)
  completTokens Int      @default(0)
  totalTokens   Int      @default(0)
  costUsd       Float    @default(0)
  latencyMs     Int?
  role          String?
  timestamp     DateTime @default(now())

  run     Run?     @relation(fields: [runId], references: [id])
  runStep RunStep? @relation(fields: [runStepId], references: [id])

  @@index([scopeId, timestamp])
  @@index([model, timestamp])
  @@index([runId])
  @@index([agentId, timestamp])
  @@map("cost_events")
}

// ────────────────────────────────────────────────────────────
// APPROVALS
// ────────────────────────────────────────────────────────────

model Approval {
  id          String    @id @default(cuid())
  runId       String
  runStepId   String?
  scopeType   String
  scopeId     String
  status      String    @default("pending")
  requestedAt DateTime  @default(now())
  resolvedAt  DateTime?
  resolvedBy  String?
  reason      String?
  context     Json?     @default("{}")
  metadata    Json?     @default("{}")

  run     Run      @relation(fields: [runId], references: [id])
  runStep RunStep? @relation(fields: [runStepId], references: [id])
  comments ApprovalComment[]

  @@index([scopeId, status])
  @@index([runId])
  @@map("approvals")
}

model ApprovalComment {
  id         String   @id @default(cuid())
  approvalId String
  authorId   String
  authorType String   @default("user")
  content    String   @db.Text
  createdAt  DateTime @default(now())

  approval Approval @relation(fields: [approvalId], references: [id], onDelete: Cascade)

  @@index([approvalId])
  @@map("approval_comments")
}

// ────────────────────────────────────────────────────────────
// ROUTINES
// ────────────────────────────────────────────────────────────

model Routine {
  id          String   @id @default(cuid())
  workspaceId String
  agentId     String?
  flowId      String?
  name        String
  description String?  @default("")
  schedule    String
  payload     Json?    @default("{}")
  isEnabled   Boolean  @default(true)
  lastRunAt   DateTime?
  nextRunAt   DateTime?
  lastRunId   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([nextRunAt])
  @@map("routines")
}

// ────────────────────────────────────────────────────────────
// ACTIVITY LOG
// ────────────────────────────────────────────────────────────

model ActivityLog {
  id         String   @id @default(cuid())
  scopeType  String
  scopeId    String
  actorType  String
  actorId    String?
  action     String
  payload    Json?    @default("{}")
  createdAt  DateTime @default(now())

  agency     Agency?     @relation(fields: [scopeId], references: [id])
  department Department? @relation(fields: [scopeId], references: [id])
  workspace  Workspace?  @relation(fields: [scopeId], references: [id])
  agent      Agent?      @relation(fields: [scopeId], references: [id])

  @@index([scopeId, createdAt])
  @@index([action, createdAt])
  @@index([actorId, createdAt])
  @@map("activity_logs")
}

// ────────────────────────────────────────────────────────────
// AGENT WAKEUP REQUESTS
// ────────────────────────────────────────────────────────────

model AgentWakeupRequest {
  id          String    @id @default(cuid())
  agentId     String
  runId       String?
  runStepId   String?
  reason      String
  payload     Json?     @default("{}")
  status      String    @default("pending")
  scheduledAt DateTime?
  processedAt DateTime?
  createdAt   DateTime  @default(now())

  agent   Agent    @relation(fields: [agentId], references: [id])
  run     Run?     @relation(fields: [runId], references: [id])
  runStep RunStep? @relation(fields: [runStepId], references: [id])

  @@index([agentId, status])
  @@index([runId])
  @@index([scheduledAt])
  @@map("agent_wakeup_requests")
}
